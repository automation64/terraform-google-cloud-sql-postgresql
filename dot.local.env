# WARNING: copy this file to .local.env to enable
#!/usr/bin/env bash
#
# Dev / Local variables
#
# * This file must be excluded from GIT
# * Automatically loaded by dev-set on non CICD environments
# * For CICD environments, create variables and values based on this file
# * Source before .env
# * Version: 1.0.0
# * Template: 3.0.1
#

#
# Project specific variables
#

# Disable guardrails during test time
export DEV_DEPLOY_OPENTOFU_GUARDRAIL_ENABLED=NO
export DEV_REMOVE_OPENTOFU_GUARDRAIL_ENABLED=NO

# Test time variables
export TF_VAR_shared__location="X_VALUE_X"
export TF_VAR_shared__project_id="X_VALUE_X"

export TF_VAR_google_sql_database_instance__settings='{
  "tier": "db-f1-micro",
  "final_backup_config": {
    "enabled": "false"
  },
  "ip_configuration": {
    "allocated_ip_range": "X_RANGE_NAME_X",
    "private_network": "X_NETWORK_SELF_LINK_X"
  }
}'
